#!/bin/bash
DISP=${1:-:0}
[[ "$DISP" =~ ^: ]] || { DISP=":$DISP"; }
shift 2>/dev/null
rm -f "$HOME/profiles/chrome-main/SingletonLock" "$HOME/profiles/chrome-main/Profile 1/SingletonLock" 2>/dev/null
DISPLAY="$DISP" google-chrome \
  --user-data-dir="$HOME/profiles/chrome-main" \
  --profile-directory="Profile 1" \
  --no-first-run \
  --no-default-browser-check \
  "$@" &
