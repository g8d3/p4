#!/usr/bin/env python3
"""hf — Higgsfield CLI.

Commands:
  hf read images          Scan Library, export all images to CSV
  hf create image <prompt>  Generate image (alias for higgsfield-gen)
"""

import subprocess, sys, json, os, re, csv, time, pathlib, datetime

HERE = pathlib.Path(__file__).resolve().parent
CSV = pathlib.Path(os.environ.get("CSV", HERE.parent / "sites/higgsfield/output/images.csv"))
CSV.parent.mkdir(parents=True, exist_ok=True)

def ab(*args):
    r = subprocess.run(["agent-browser", "--auto-connect"] + list(args),
                       capture_output=True, text=True, timeout=60)
    return r.stdout.strip(), r.stderr.strip()

def parse_result(out):
    if not out or out.strip() == "null":
        return {"found": False}
    try:
        raw = json.loads(out)
    except json.JSONDecodeError:
        return {"found": False}
    if raw is None:
        return {"found": False}
    if isinstance(raw, list):
        if not raw:
            return {"found": False}
        inner = raw[0]
        if isinstance(inner, str):
            try:
                return json.loads(inner)
            except json.JSONDecodeError:
                return {"found": False}
        return inner if isinstance(inner, dict) else {"found": False}
    if isinstance(raw, str):
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            return {"found": False}
    return raw if isinstance(raw, dict) else {"found": False}

def cmd_read_images():
    print("Scanning Library...")
    ab("open", "https://higgsfield.ai/library/image")
    time.sleep(5)

    # Get all cards with their data
    out, _ = ab("eval", """
    (() => {
        const els = document.querySelectorAll('button, [onclick], [class*=clickable]');
        const results = [];
        for (const el of els) {
            const text = el.textContent || '';
            const html = el.outerHTML || '';
            const jobId = (html.match(/[a-f0-9-]{36}/) || [''])[0];
            const img = el.querySelector('img');
            const imgUrl = img?.src || '';
            const imgAlt = img?.alt || '';
            const status = imgAlt.includes('media asset') ? 'completed' : 'pending';
            // Extract prompt: first meaningful text before 'Seedream' or similar
            const prompt = text.replace(/\\s*Seedream.*$/, '').replace(/\\s*\\d+/g, '').trim();
            if (jobId || prompt.length > 10) {
                results.push({jobId, prompt: prompt.substring(0, 200), imageUrl: imgUrl, status, model: 'seedream_v4_5'});
            }
        }
        return JSON.stringify(results.slice(0, 50));
    })()
    """)
    cards = parse_result(out)
    if not cards or not isinstance(cards, list):
        print(f"No cards found: {cards}")
        return

    # Write CSV (replace)
    cols = ["datetime", "story", "chapter", "scene", "prompt", "job_id", "image_url", "status", "model", "aspect", "duration_ms"]
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(CSV, "w", newline="") as f:
        w = csv.writer(f, quoting=csv.QUOTE_NONNUMERIC)
        w.writerow(cols)
        for c in cards:
            if c.get("jobId") or len(c.get("prompt", "")) > 10:
                w.writerow([now, "", "", "", c.get("prompt", ""),
                          c.get("jobId", ""), c.get("imageUrl", ""),
                          c.get("status", "completed"),
                          c.get("model", "seedream_v4_5"), "", ""])
    print(f"Written {len(cards)} cards to {CSV}")

def cmd_create(args):
    prompt = args[0] if args else "default"
    model = args[1] if len(args) > 1 else "seedream_v4_5"
    env = os.environ.copy()
    env["CSV"] = str(CSV)
    r = subprocess.run([sys.argv[0].replace("hf", "higgsfield-gen"), prompt, model],
                       capture_output=True, text=True, timeout=120, env=env)
    print(r.stdout)
    if r.stderr:
        print(r.stderr, file=sys.stderr)

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        return
    cmd = sys.argv[1]
    if cmd == "read" and len(sys.argv) > 2 and sys.argv[2] == "images":
        cmd_read_images()
    elif cmd == "create" and len(sys.argv) > 3 and sys.argv[2] == "image":
        cmd_create(sys.argv[3:])
    else:
        print(f"Unknown command: {' '.join(sys.argv[1:])}")
        print(__doc__)

if __name__ == "__main__":
    main()
