#!/bin/bash
# higgsfield-gen — Generate AI images on Higgsfield via agent-browser.
# Usage: higgsfield-gen "<prompt>" [model]
#   model defaults to seedream_v4_5

PROMPT="${1:-A frustrated developer staring at a glowing screen filled with console errors}"
MODEL="${2:-seedream_v4_5}"
URL="https://higgsfield.ai/mobile/image/$MODEL"
STATS_FILE="${HIGGSFIELD_STATS:-./log/higgsfield-stats.jsonl}"
mkdir -p "$(dirname "$STATS_FILE")"

if ! curl -sf http://localhost:9222/json/version > /dev/null 2>&1; then
    echo "Chrome not running on port 9222 — start sway-chrome first" >&2
    exit 1
fi

ab() { agent-browser --auto-connect "$@" > /dev/null 2>&1; }

now_ms() { date +%s%3N; }
t0=$(now_ms); t_step=$t0

step() {
    local name="$1" now=$(now_ms)
    echo "$(( now - t_step ))ms  $name"
    t_step=$now
}

step "Clearing draft..."
ab eval "localStorage.removeItem('hf:image-form-upd')"
step "Navigating..."
ab open "$URL"
step "Setting prompt..."
ab fill "[placeholder*='Describe']" "$PROMPT"
step "Enabling Unlimited..."
ab eval "
  const sw = document.querySelector('[role=switch]');
  if (sw && sw.getAttribute('aria-checked') !== 'true') sw.click();
"
step "Generating..."
har_file="/tmp/higgsfield-$(date +%s).har"
ab network har start "$har_file"
ab eval "document.getElementById('image-submit-button')?.click()"
step "Waiting for generation..."
ab snapshot
ab network har stop
step "Done"

total_ms=$(( $(now_ms) - t0 ))
echo "=== ${total_ms}ms ==="

echo "{\"ts\":$(date +%s),\"total_ms\":$total_ms,\"prompt_len\":${#PROMPT},\"model\":\"$MODEL\"}" >> "$STATS_FILE"

tail -5 "$STATS_FILE" 2>/dev/null | python3 -c "
import json, sys
lines = [json.loads(l) for l in sys.stdin if l.strip()]
if not lines: exit()
for l in lines:
    s = l['total_ms']
    m, s2 = divmod(s // 1000, 60)
    print(f'  {m}m{s2:02d}s  prompt_len={l[\"prompt_len\"]}  model={l[\"model\"]}')
avg = sum(l['total_ms'] for l in lines) / len(lines) / 1000
print(f'  avg: {avg:.0f}s')
" 2>/dev/null