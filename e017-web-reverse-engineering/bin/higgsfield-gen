#!/usr/bin/env python3
"""higgsfield-gen — Generate AI images on Higgsfield.

Usage:
  higgsfield-gen "<prompt>" [model]
  STORY=auto CHAPTER=scene1 SCENE=1 higgsfield-gen "<prompt>"
"""

import subprocess, sys, json, os, re, csv, time, pathlib, datetime

HERE = pathlib.Path(__file__).resolve().parent
CSV = pathlib.Path(os.environ.get("CSV", HERE / "../sites/higgsfield/output/images.csv"))
CSV.parent.mkdir(parents=True, exist_ok=True)
if not CSV.exists():
    CSV.write_text("datetime,story,chapter,scene,prompt,job_id,image_url,status,model,aspect,duration_ms\n")

def ab(*args):
    r = subprocess.run(["agent-browser", "--auto-connect"] + list(args),
                       capture_output=True, text=True, timeout=60)
    return r.stdout.strip(), r.stderr.strip()

def ab_eval(js):
    out, _ = ab("eval", js)
    return out.strip('"') if out else ""

def now_fmt():
    return datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def main():
    prompt = sys.argv[1] if len(sys.argv) > 1 else "default prompt"
    model = sys.argv[2] if len(sys.argv) > 2 else "seedream_v4_5"
    story = os.environ.get("STORY", "")
    chapter = os.environ.get("CHAPTER", "")
    scene = os.environ.get("SCENE", "")
    gen_url = f"https://higgsfield.ai/mobile/image/{model}"
    prefix = prompt[:40]
    t0 = time.time()

    def step(label):
        print(f"{int((time.time()-t0)*1000)}ms  {label}")

    # Navigate to generation page
    step("Navigating...")
    cur = ab_eval("location.href")
    if "/mobile/image" not in cur and "/ai/image" not in cur:
        ab_eval("localStorage.removeItem('hf:image-form-upd')")
        ab("open", gen_url)

    # Set prompt
    step("Setting prompt...")
    ab("click", "[placeholder*='Describe']")
    time.sleep(1)
    ab("keyboard", "type", prompt)
    time.sleep(2)
    val = ab_eval("document.querySelector('textarea')?.value?.length || 0")
    if int(val or 0) <= 5:
        ab("click", "[placeholder*='Describe']")
        time.sleep(1)
        ab("keyboard", "type", prompt)
        time.sleep(2)
        val = ab_eval("document.querySelector('textarea')?.value?.length || 0")
        if int(val or 0) <= 5:
            print("  ABORT")
            sys.exit(1)
    print(f"  prompt: {prompt[:40]}...")

    # Unlimited
    step("Unlimited...")
    ab_eval("document.querySelector('[role=switch]')?.click()")

    # Click generate
    step("Generating...")
    ab_eval("document.getElementById('image-submit-button')?.click()")

    # Find card by prompt
    step("Finding card...")
    card = "null"
    for _ in range(30):
        out, _ = ab("eval", f"""
        (() => {{
            const els = document.querySelectorAll('button, [onclick], [class*=clickable]');
            for (const el of els) {{
                if (el.textContent.includes({json.dumps(prefix)})) {{
                    const html = el.outerHTML || '';
                    const id = html.match(/[a-f0-9-]{{36}}/)?.[0] || '';
                    const img = el.querySelector('img');
                    return JSON.stringify({{found: true, jobId: id, imageUrl: img?.src || ''}});
                }}
            }}
            return 'null';
        }})()
        """)
        card = out.strip()
        if card != "null":
            break
        time.sleep(2)

    print(f"  raw card=[{card[:80]}]", file=sys.stderr)
    if card and card not in ("null", '"null"', '[]'):
        raw = json.loads(card)
        inner = raw[0] if isinstance(raw, list) else raw
        data = json.loads(inner) if isinstance(inner, str) else inner
        job_id = data.get("jobId", "pending")
        img_url = data.get("imageUrl", "")
        print(f"  ✅ {job_id}")
        ms = int((time.time() - t0) * 1000)
        with open(CSV, "a", newline="") as f:
            w = csv.writer(f, quoting=csv.QUOTE_NONNUMERIC)
            w.writerow([now_fmt(), story, chapter, scene, prompt,
                       job_id, img_url, "pending", model, "9:16", ms])
    else:
        print("  ❌ card not found")

    print(f"=== {int((time.time()-t0)*1000)}ms ===")

if __name__ == "__main__":
    main()
