#!/bin/bash
PROMPT="${1:-default prompt}"
MODEL="${2:-seedream_v4_5}"
LIBRARY_URL="https://higgsfield.ai/library/image"
GEN_URL="https://higgsfield.ai/mobile/image/$MODEL"
CSV="${CSV:-./sites/higgsfield/output/images.csv}"
mkdir -p "$(dirname "$CSV")"
[ -f "$CSV" ] || echo "ts,story,chapter,scene,prompt,job_id,image_url,status,model,aspect,duration_ms" > "$CSV"

ab() { agent-browser --auto-connect "$@" > /dev/null 2>&1; }
step() { local n="$1" now=$(date +%s%3N); echo "$(( now - t_step ))ms  $n" >&2; t_step=$now; }
t0=$(date +%s%3N); t_step=$t0

check() {
    local label="$1" js="$2"
    local result=$(agent-browser --auto-connect eval "$js" 2>/dev/null)
    [ "$result" = "true" ] && return 0
    echo "  ❌ $label: $result" >&2
    return 1
}

# 1. Navigate to Library if not already there
step "Counting library images..."
current_url=$(agent-browser --auto-connect eval "location.href" 2>/dev/null)
if [[ "$current_url" != */library/* ]]; then
    ab open "$LIBRARY_URL"
fi
# Wait for RSC to render cards
for i in 1 2 3 4 5; do
    c=$(agent-browser --auto-connect eval "
        document.querySelectorAll('img[alt*=media]').length
    " 2>/dev/null)
    [ "${c:-0}" -gt 0 ] && break
    sleep 2
done
before="$c"
echo "  $before items in library" >&2

# 2. Navigate to generation page if not already there
step "Clearing draft + navigating..."
current_url=$(agent-browser --auto-connect eval "location.href" 2>/dev/null)
if [[ "$current_url" != */mobile/image/* ]]; then
    ab eval "localStorage.removeItem('hf:image-form-upd')"
    ab open "$GEN_URL"
fi

# 3. Set prompt
step "Setting prompt..."
ab click "[placeholder*='Describe']"
sleep 2
ab keyboard type "$PROMPT"
sleep 3
pval=$(agent-browser --auto-connect eval "document.querySelector('textarea')?.value?.length || 0" 2>/dev/null)
if [ "${pval:-0}" -gt 5 ]; then
    echo "  prompt: ${PROMPT:0:40}..." >&2
else
    echo "  ❌ prompt empty (len=$pval), retrying..." >&2
    ab click "[placeholder*='Describe']"
    sleep 1
    ab keyboard type "$PROMPT"
    sleep 3
    pval2=$(agent-browser --auto-connect eval "document.querySelector('textarea')?.value?.length || 0" 2>/dev/null)
    [ "${pval2:-0}" -le 5 ] && { echo "  ABORT (prompt not set)"; exit 1; }
fi

# 4. Enable unlimited
step "Enabling Unlimited..."
ab eval "document.querySelector('[role=switch]')?.click()"
check "unlimited enabled" "document.querySelector('[role=switch]')?.getAttribute('aria-checked') === 'true'" || echo "  ⚠️ unlimited may not be active" >&2

# 5. Click generate
step "Generating..."
ab eval "document.getElementById('image-submit-button')?.click()"
ab snapshot

# 6. Wait for Library + find the card by prompt text
step "Waiting for result..."
card_json="null"
for i in 1 2 3 4 5; do
    card_json=$(agent-browser --auto-connect eval "
        (() => {
            const els = [...document.querySelectorAll('button, [onclick], [class*=clickable]')];
            const match = els.find(e => e.textContent.includes('${PROMPT:0:40}'));
            if (!match) return 'null';
            const matchText = match.outerHTML || '';
            const id = matchText.match(/[a-f0-9-]{36}/)?.[0] || '';
            const img = match.querySelector('img');
            return JSON.stringify({found: true, jobId: id, imageUrl: img?.src || ''});
        })()
    " 2>/dev/null)
    [ "$card_json" != "null" ] && break
    sleep 2
done

# One final check with longer wait
if [ "$card_json" = "null" ]; then
    sleep 5
    card_json=$(agent-browser --auto-connect eval "
        const els = [...document.querySelectorAll('button, [onclick], [class*=clickable]')];
        const match = els.find(e => e.textContent.includes('${PROMPT:0:40}'));
        if (!match) return 'null';
        const matchText = match.outerHTML || '';
        const id = matchText.match(/[a-f0-9-]{36}/)?.[0] || '';
        const img = match.querySelector('img');
        return JSON.stringify({found: true, jobId: id, imageUrl: img?.src || ''});
    " 2>/dev/null)
fi

found=$(echo "$card_json" | python3 -c "import sys,json; d=json.loads(sys.stdin); print(d.get('found','false'))" 2>/dev/null)
if [ "$found" = "True" ]; then
    job_id=$(echo "$card_json" | python3 -c "import sys,json; print(json.load(sys.stdin).get('jobId',''))" 2>/dev/null)
    image_url=$(echo "$card_json" | python3 -c "import sys,json; print(json.load(sys.stdin).get('imageUrl',''))" 2>/dev/null)
    [ -z "$job_id" ] && job_id="pending"
    echo "  ✅ $job_id" >&2
    echo "$(date +%s),,,,\"${PROMPT//\"/\"\"}\",$job_id,$image_url,pending,$MODEL,9:16,$(( $(date +%s%3N) - t0 ))" >> "$CSV"
else
    echo "  ❌ card not found" >&2
fi

total_ms=$(( $(date +%s%3N) - t0 ))
echo "=== ${total_ms}ms ===" >&2
